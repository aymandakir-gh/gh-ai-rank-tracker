# gh-ai-rank-tracker — environment variables (engine + Hono API)
# Copy to .env and fill in only what you need. NEVER commit your real .env.
# The web UI has its own env file at web/.env.example.

# ── Live answer-engine adapters ───────────────────────────────────────────────
# Each adapter reads its key from the environment. Any provider whose key is
# absent is simply unavailable; the offline MockProvider is always the default.
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are used when unset):
#   OPENAI_MODEL=gpt-4o
#   PERPLEXITY_MODEL=sonar
#   ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Hono API server (src/server.ts) ───────────────────────────────────────────
# Bearer token required to call POST /api/scan in production. Generate with:
#   openssl rand -hex 32
SCAN_API_KEY=

# Set to "development" to run the server without SCAN_API_KEY (local only).
# NODE_ENV=development

# TCP port (Railway injects this automatically in production).
# PORT=3000

# Enable the Aegis input guard (prompt-injection + jailbreak screening).
# AEGIS_ENABLED=true

# ── Campaign history store (tracking over time) ───────────────────────────────
# Local-first JSON file recording each campaign run (no external DB). The CLI
# (`campaign run/list/history`) and the API (/api/campaign) persist here.
# Default: ./.tracker/store.json
# TRACKER_STORE_PATH=./.tracker/store.json
