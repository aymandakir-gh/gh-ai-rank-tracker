{
  "name": "gh-ai-rank-tracker",
  "version": "0.3.0",
  "description": "Track whether AI answer engines (ChatGPT, Perplexity, Google AI Overviews, Gemini) mention and cite your brand. A GEO/AEO visibility & share-of-voice tracker.",
  "type": "module",
  "license": "MIT",
  "author": "GrowthHackers (GH)",
  "homepage": "https://growthackers.io",
  "keywords": [
    "geo",
    "generative-engine-optimization",
    "aeo",
    "answer-engine-optimization",
    "ai-search",
    "llm-seo",
    "share-of-voice",
    "brand-monitoring",
    "rank-tracker",
    "perplexity",
    "chatgpt",
    "seo"
  ],
  "bin": {
    "gh-ai-rank-tracker": "dist/src/cli.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx src/cli.ts --demo",
    "cli": "tsx src/cli.ts",
    "analyze": "tsx src/cli.ts",
    "api:dev": "tsx src/server.ts",
    "start": "node dist/src/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
