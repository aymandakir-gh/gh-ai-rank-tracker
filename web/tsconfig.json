{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@engine": ["../src/web.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../src/**/*.ts"
  ],
  // The web app consumes the engine via @engine → ../src/web.ts (Hono-free).
  // Exclude the Hono API entrypoints — they import `hono` / `@hono/node-server`,
  // which are root-only deps not installed in the web project (CI typechecks web
  // in isolation). They are covered by the root project's typecheck.
  "exclude": ["node_modules", "../src/api", "../src/server.ts", "../src/index.ts"]
}
