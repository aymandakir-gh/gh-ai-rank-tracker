# ── Email gate / lead capture (optional) ─────────────────────────────────────
# When set, the Share button in the results page fires a lead capture request.
# The Next.js API route POST /api/lead will proxy to: ${LEADS_API_URL}/api/lead
# Body sent: { email, source: "ai-rank-tracker", brandName, visibilityScore }
# Leave empty to silently skip lead capture.
LEADS_API_URL=

# ── Site URL (used for OG metadata) ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gh-ai-rank-tracker.vercel.app

# ── Sentry error monitoring (optional — graceful degrade when absent) ─────────
# DSN from https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# ── PostHog product analytics (optional — graceful degrade when absent) ───────
# Key from https://app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
# Default: https://eu.i.posthog.com  (EU cloud). Override for US cloud:
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
