# URL of the running gh-ai-rank-tracker API server (Hono backend on port 3000)
# In dev: run `npm run api:dev` in repo root, then `npm run dev` here
SCAN_API_URL=http://localhost:3000

# Bearer token for the API — must match SCAN_API_KEY on the server
# Leave empty for open/dev mode (no auth)
SCAN_API_KEY=

# Optional: set on the API server to enable live Perplexity provider
# PERPLEXITY_API_KEY=
