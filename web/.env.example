# ── Email gate / lead capture (optional) ─────────────────────────────────────
# When set, the Share button in the results page fires a lead capture request.
# The Next.js API route POST /api/lead will proxy to: ${LEADS_API_URL}/api/lead
# Body sent: { email, source: "ai-rank-tracker", brandName, visibilityScore }
# Leave empty to silently skip lead capture.
LEADS_API_URL=

# ── Site URL (used for OG metadata) ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gh-ai-rank-tracker.vercel.app
